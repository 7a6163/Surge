#!name=Dodopayments License Activate Bypass
#!desc=Short-circuit POST live.dodopayments.com/licenses/activate and return fixed JSON without upstream call v202606070002
#!category=Unlock

[Script]
Dodopayments-License = type=http-request, pattern=^https:\/\/live\.dodopayments\.com\/licenses\/activate(\?|$), script-path=https://raw.githubusercontent.com/7a6163/Surge/main/Script/Dodopayments-license.js, requires-body=false, timeout=10

[MITM]
hostname = %APPEND% live.dodopayments.com
