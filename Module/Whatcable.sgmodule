#!name=WhatCable 驗證偽造
#!desc=攔截 whatcable.uk/api/validate POST 請求並直接回傳 {"valid":true}（不送上游） v202606070001
#!category=Unlock

[Script]
Whatcable-Validate = type=http-request, pattern=^https:\/\/whatcable\.uk\/api\/validate(\?|$), script-path=https://raw.githubusercontent.com/7a6163/Surge/main/Script/Whatcable-validate.js, requires-body=false, timeout=10

[MITM]
hostname = %APPEND% whatcable.uk
